      ],
      "id": "c9930639-587b-4448-9613-b30a3b8be105",
      "name": "6. Export Completo"
    },
    {
      "parameters": {
        "jsCode": "const ifItems     = $('5. Mudou?').all();\nconst exportItems = $('6. Export Completo').all();\n\nconst results = [];\nfor (let i = 0; i < ifItems.length; i++) {\n  const orig       = ifItems[i].json;\n  const fullExport = exportItems[i] ? exportItems[i].json : {};\n\n  delete fullExport.id;\n  delete fullExport.createdAt;\n  delete fullExport.updatedAt;\n  delete fullExport.pinData;\n  delete fullExport.executionData;\n  delete fullExport.triggerTime;\n  delete fullExport.owner;\n  delete fullExport.shared;\n  delete fullExport.meta;\n\n  // versionId permanece — usado para comparação incremental no próximo backup\n\n  const content       = JSON.stringify(fullExport, null, 2);\n  const commitMessage = 'backup: ' + orig.workflowName + ' (v:' + (orig.versionId || '').substring(0, 8) + ')';\n\n  results.push({\n    json: {\n      workflowId:   orig.workflowId,\n      workflowName: orig.workflowName,\n      githubPath:   orig.githubPath,\n      content,\n      commitMessage,\n      fileSha: orig.fileSha || ''\n    }\n  });\n}\n\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
