      "id": "34ae085e-d87a-461f-8514-59a9d27e97fb",
      "name": "8d. Merge Push"
    },
    {
      "parameters": {
        "jsCode": "const montar      = $('7. Montar JSON').all();\nconst pushResults = $input.all();\n\nconst success = [];\nconst errors  = [];\n\nfor (let i = 0; i < pushResults.length; i++) {\n  const p    = pushResults[i].json;\n  const name = p.workflowName || (montar[i] ? montar[i].json.workflowName : 'Workflow #' + (i + 1));\n\n  if (p.commit || (p.content && typeof p.content === 'object' && p.content.sha)) {\n    success.push(name);\n  } else {\n    errors.push(name);\n  }\n}\n\nconst now = new Date().toLocaleString('pt-BR', { timeZone: 'America/Sao_Paulo' });\nlet text  = `✅ *Backup n8n concluído!*\\n\\n🕐 ${now}\\n\\n`;\n\nif (success.length > 0) {\n  text += `📦 *${success.length} workflow(s) atualizado(s):*\\n`;\n  text += success.map(n => '• ' + n).join('\\n');\n} else {\n  text += 'Nenhum workflow foi alterado.';\n}\n\nif (errors.length > 0) {\n  text += `\\n\\n⚠️ *${errors.length} erro(s) no push:*\\n`;\n  text += errors.map(n => '• ' + n).join('\\n');\n}\n\nreturn [{ json: { success: success.length, errors: errors.length, text } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
